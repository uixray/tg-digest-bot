# =============================================================================
# Telegram Digest Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Telegram Bot (get from @BotFather)
# -----------------------------------------------------------------------------
BOT_TOKEN=123456:ABC-DEF...
OWNER_CHAT_ID=123456789

# -----------------------------------------------------------------------------
# REQUIRED: GramJS Userbot (get from https://my.telegram.org/apps)
# -----------------------------------------------------------------------------
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abc123def456...

# Session string - will be filled automatically after running: npm run auth
TELEGRAM_SESSION=

# -----------------------------------------------------------------------------
# REQUIRED: PostgreSQL Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/tg_digest

# -----------------------------------------------------------------------------
# OPTIONAL: AI Summarization
# -----------------------------------------------------------------------------

# AI provider: "yandexgpt" | "lmstudio" | "none"
AI_PROVIDER=none

# LM Studio (local, recommended)
# Download from: https://lmstudio.ai/
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# YandexGPT (cloud)
# Get credentials from: https://cloud.yandex.ru/
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: Digest Schedule
# -----------------------------------------------------------------------------

# Cron expression for automatic digests (default: daily at 9:00)
# Examples:
#   "0 9 * * *"     - Every day at 9:00
#   "0 9 * * 1-5"   - Weekdays at 9:00
#   "0 9,18 * * *"  - Twice daily at 9:00 and 18:00
#   ""              - Disable auto-digest
DIGEST_CRON=0 9 * * *
DIGEST_TIMEZONE=Europe/Moscow

# -----------------------------------------------------------------------------
# FUTURE: Obsidian Integration (v1.2)
# -----------------------------------------------------------------------------

# Path to your Obsidian vault
# OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Folder for digests inside the vault
# OBSIDIAN_DIGESTS_FOLDER=Digests

# Template: "default" or path to custom template
# OBSIDIAN_TEMPLATE=default

# Auto-export digests to Obsidian
# OBSIDIAN_AUTO_EXPORT=false

# -----------------------------------------------------------------------------
# FUTURE: RAG Search (v1.1)
# -----------------------------------------------------------------------------

# Embedding model for local vector search
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Enable image descriptions for media messages
# ENABLE_IMAGE_DESCRIPTIONS=false
